			<Item class="LocalScript" referent="RBX009C06799D7843BABC2040AF5A868D98">
				<Properties>
					<ProtectedString name="Source"><![CDATA[------------------------
--//Static Variables\\--
------------------------

local UIS = game:GetService("UserInputService")

local car = script.Parent:WaitForChild("Car").Value
local remote = car:WaitForChild("EasyLS_Remote")
local config = require(remote:WaitForChild("EasyLS_Config"))

-------------------------
--//Dynamic Variables\\--
-------------------------

local listeningFor = {}

-----------------
--//Functions\\--
-----------------

local function handleAction(action,state)
	remote:InvokeServer(action,state)
end

local function handleBind(keycode,state)
	if state then
		if not table.find(listeningFor,keycode) then --just to be safe
			table.insert(listeningFor,keycode)
		end
	else
		local ind = table.find(listeningFor,keycode)
		if ind then
			table.remove(listeningFor,ind)
		end
	end
end

-----------
--//Core\\-
-----------

remote.OnClientInvoke = handleBind

local binds = remote:InvokeServer("GetBinds")
for _,v in ipairs(binds) do
	handleBind(v,true)
end

UIS.InputBegan:Connect(function(inp,gp)
	if not gp then
		if table.find(config.mainLightsKeybind,inp.KeyCode) then
			handleAction("MainELS",Enum.UserInputState.Begin)
		elseif table.find(config.directorLightsKeybind,inp.KeyCode) then
			handleAction("DirectorELS",Enum.UserInputState.Begin)
		elseif table.find(listeningFor,inp.KeyCode) then
			handleAction(tostring(inp.KeyCode),Enum.UserInputState.Begin)
		end
	end
end)

UIS.InputEnded:Connect(function(inp,gp)
	if not gp then
		if table.find(listeningFor,inp.KeyCode) then
			handleAction(tostring(inp.KeyCode),Enum.UserInputState.End)
		end
	end
end)]]></ProtectedString>
