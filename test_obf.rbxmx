									<bool name="DefinesCapabilities">false</bool>
									<string name="Name">Connection</string>
									<int64 name="SourceAssetId">-1</int64>
									<BinaryString name="Tags"></BinaryString>
								</Properties>
							</Item>
						</Item>
					</Item>
					<Item class="ModuleScript" referent="RBX63005839D95A4D44BD9DB2DBDD532696">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local settings = {}

---------------------
--//Lighting Mode\\--
---------------------
settings.lightingMethod = "neon" --Either "neon" or "textured" or "both"
settings.neonLightOnTransparency = .02 --Transparency of lights when they are on.  Slightly raise this value to make it bloom through opaque surfaces

----------------------
--//Color Settings\\--
----------------------
settings.brickLightColors = { --The color of neon parts if you chose neon lighting, the color of the light surface UIs if you chose gui lighting
	["Red"] = Color3.fromRGB(190,104,98),
	["Blue"] = Color3.fromRGB(110,153,202),
	["White"] = Color3.fromRGB(255,255,255),
	["Amber"] = Color3.fromRGB(213,115,61),
	["Green"] = Color3.fromRGB(32,255,29),
}

settings.ambientLightColors = { --The color any environment lighting
	["Red"] = Color3.new(1,0,0),
	["Blue"] = Color3.new(0,0,1),
	["White"] = Color3.new(1,1,1),
	["Amber"] = Color3.new(1,.7,0),
	["Green"] = Color3.new(0,1,0),
}

----------------
--//Keybinds\\--
----------------
settings.mainLightsKeybind = { --These keybinds cycle the three main ELS patterns.  You may have as few or as many keybinds as you wish
	Enum.KeyCode.J,
	Enum.KeyCode.DPadRight,
} 
settings.directorLightsKeybind = { --These keybinds cycle the director patterns.  You may have as few or as many keybinds as you wish
	Enum.KeyCode.K,
	Enum.KeyCode.DPadLeft,
} 

return settings]]></ProtectedString>
