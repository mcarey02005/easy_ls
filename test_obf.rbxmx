							</Properties>
						</Item>
						<Item class="ModuleScript" referent="RBX62303EBB716C4E4EA07DEEF870089522">
							<Properties>
								<Content name="LinkedSource"><null></null></Content>
								<ProtectedString name="Source"><![CDATA[--//You will have to understand how to program to make addons
--//See the "AddonDocumentation" script for help

return function(addonLibrary)
	--write your addon in this function
	
	
	
	--[[
	
	EXAMPLE:
	
	addonLibrary.keystroke(Enum.Keycode.R):Connect(function()
		print("Play a siren!")
	end)
	
	print(addonLibrary.DriveSeat.Name) -"DriveSeat"
	
	]]
end]]></ProtectedString>
