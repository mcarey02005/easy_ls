					<string name="ScriptGuid">{78A8266D-CA05-4067-97E8-E786186ACA25}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<string name="Name">EasyLS_Client</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
				</Properties>
				<Item class="RemoteFunction" referent="RBXB66561B2C6CE449B9C95DBC46AD3381F">
					<Properties>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<string name="Name">EasyLS_Remote</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
					</Properties>
					<Item class="Script" referent="RBX7CD5B853BDEA43429A26F8235935A1B9">
						<Properties>
							<ProtectedString name="Source"><![CDATA[repeat task.wait() until script.Parent.Parent.ClassName ~= "LocalScript"

------------------------
--//Static Variables\\--
------------------------

local players = game:GetService("Players")

local remote = script.Parent
local car = remote.Parent
local patternsFolder = remote:WaitForChild("Patterns")
local lightsParent = remote:WaitForChild("LightsParent")
local addons = script.Parent:WaitForChild("Addons")
local driveSeat = car:WaitForChild("DriveSeat")

local config = require(remote:WaitForChild("EasyLS_Config"))
local authenticatePattern = require(script:WaitForChild("AuthenticatePattern"))
local rawcopy = require(script:WaitForChild("Rawcopy"))
local signalObject = require(script:WaitForChild("Signal"))

local stageChangedSignal = signalObject.new() --TODO: This can be nil by default, and then made when its needed.  J make a gc callback for it and implement it in addon lib

-------------------------
--//Dynamic Variables\\--
-------------------------

local allStageData = {} --//{steps,stepSpacing,data,f}
--//where data = {{lightObj=...,data=stuffHere},{lightObj=...,data=stuffHere}}
local allDirectorData = {}--same as above

local lightsInvolvedInLastPattern = {["Stage"]={},["Director"]={}}
local lightsInvolvedInCurrentPattern = {["Stage"]={},["Director"]={}}

local currentELSstage = 0
local currentDirectorStage = 0

local elsStep = 0
local directorStep = 0

local useNeon = (table.find({"neon","both"},config.lightingMethod)~=nil)
local recognizeTextures = (table.find({"textured","both"},config.lightingMethod)~=nil)

local pluginKeyListeners = {} --{keycode = {listeners}}
local ignoreLights = {}

local currentDriver = nil

--[[TODO: Redo data format so light FX are stored in ONE place, not with each light imported from the editor individuallly.
The place where lights are stored individualy per step should point to this "MasterFX" table.
This will allow better addon support and increase performance]]

-----------------
--//Functions\\--
-----------------

local function textureLightOn(l,colorParts,c)
	l.Enabled = true
	
	if colorParts then
		for _,v in pairs(colorParts) do
			v.ImageColor3 = c
		end
	end
end

local function textureLightOff(l)
	l.Enabled = false
end

local function envLightOn(l,c)
	if not l.Parent:GetAttribute("Ignore") then
		l.Color = c
		l.Enabled = true
	end
end

local function envLightOff(l)
	l.Enabled = false
end

local function lightOn(l,c)
	if not l:GetAttribute("Ignore") then
		l.Transparency = config.neonLightOnTransparency
		l.Color = c
	end
end

local function lightOff(l)
	if not l:GetAttribute("Ignore") then
		l.Transparency = 1
	end
end

local function stageLightsOff()
	elsStep = 0
	for _,v in pairs(lightsInvolvedInLastPattern.Stage) do
		if not table.find(ignoreLights,v) then
			if not table.find(lightsInvolvedInCurrentPattern.Director,v) then
				lightOff(v)
				for _,v2 in pairs(v:GetChildren()) do
					if not table.find(ignoreLights,v2) then
						if v2:IsA("Light") then
							envLightOff(v2)
						elseif v2:IsA("LayerCollector") then
							textureLightOff(v2)
						end
					end
				end
			end
		end
	end
end

local function directorLightsOff()
	directorStep = 0
	for _,v in pairs(lightsInvolvedInLastPattern.Director) do
		if not table.find(ignoreLights,v) then
			lightOff(v)
			for _,v2 in pairs(v:GetChildren()) do
				if not table.find(ignoreLights,v2) then
					if v2:IsA("Light") then
						envLightOff(v2)
					elseif v2:IsA("LayerCollector") then
						textureLightOff(v2)
					end
				end
			end
		end
	end
end

local function allLightsOff()
	stageLightsOff()
	directorLightsOff()
end

local function activateLight(lightData,colorToMake,ambientColorToMake,colorName)
	if useNeon then --if in neon mode, activate part light
		lightOn(lightData[1][1],colorToMake) --light on
	end
	if recognizeTextures then --if in texture mode, activate any textures
		local textureLights = lightData[1][3].defined[colorName]
		if textureLights then
			for _,tLight in pairs(textureLights) do
				if not table.find(ignoreLights,tLight) then
					textureLightOn(tLight)
				end
			end
		else
			for _,textureLight in pairs(lightData[1][3].universal) do
				if not table.find(ignoreLights,textureLight[1]) then
					textureLightOn(textureLight[1],textureLight[2],colorToMake)
				end
			end
		end
	end
	for _,eLight in pairs(lightData[1][2]) do --env lights on
		if not table.find(ignoreLights,eLight) then
			envLightOn(eLight,ambientColorToMake)
		end
	end
end

local function deactivateLight(lightData)
	if useNeon then
		lightOff(lightData[1][1])
	end
	if recognizeTextures then
		for _,definedColor in pairs(lightData[1][3].defined) do
			for _,flashFX in pairs(definedColor) do
				if not table.find(ignoreLights,flashFX) then
					textureLightOff(flashFX)
				end
			end
		end

		for _,textureSet in pairs(lightData[1][3].universal) do
			if not table.find(ignoreLights,textureSet[1]) then
				textureLightOff(textureSet[1])
			end
		end
	end
	for _,eLight in pairs(lightData[1][2]) do
		if not table.find(ignoreLights,eLight) then
			envLightOff(eLight)
		end
	end
end

local function handleLightAction(lightData,step)
	if not table.find(ignoreLights,lightData[1][1]) then
		step = step or 1

		local colorName = lightData[2][step]
		local colorToMake = config.brickLightColors[colorName] --grab desired color
		local ambientColorToMake = config.ambientLightColors[colorName] --grab desired ambiant color
		if colorToMake then --if not nil, turn light on
			activateLight(lightData,colorToMake,ambientColorToMake,colorName)
		else
			deactivateLight(lightData)
		end
	end
end

-- Plugin Functions:

local function rawLightOff(part)
	part.Transparency = 1
	
	for _,v in pairs(part:GetChildren()) do
		if v:IsA("LayerCollector") then
			v.Enabled = false
		elseif v:IsA("Light") then
			v.Enabled = false
		end
	end
end

local function syncLight(part)
	local lightData = nil
	local isDirector = false
	
	if currentDirectorStage ~= 0 then --director is on, get desired state from director data
		for _,possibleLightData in pairs(allDirectorData[currentDirectorStage][3]) do
			if possibleLightData[1][1] == part then
				lightData = possibleLightData
				isDirector = true
				break
			end
		end
	end
	
	if lightData == nil and currentELSstage ~= 0 then --director is off, look through stage data
		for _,possibleLightData in pairs(allStageData[currentELSstage][3]) do
			if possibleLightData[1][1] == part then
				lightData = possibleLightData
				break
			end
		end
	end
	
	if lightData then
		handleLightAction(lightData,(isDirector and directorStep) or elsStep)
	else
		rawLightOff(part)
	end
end

--

local function initialize()
	--verify light mode
	if not table.find({"neon","textured","both"},config.lightingMethod) then
		warn("Unrecognized lighting method: "..tostring(config.lightingMethod)..'.  Defaulting to "neon"')
	end
	
	--verify light folder
	if lightsParent.Value == nil then
		error("No lights parent was set with the object value for car: "..car.Name)
	end
	
	--grab light parts, env lights, and textures
	local allLightParts = {}
	
	for _,v in pairs(lightsParent.Value:GetDescendants()) do
		if v:IsA("BasePart") then
			lightOff(v)
			
			local envLights = {}
			local textures = {defined={},universal={}} --{ defined={color1={guiObjects},color2={guiObjects}} , universal={ { guiObject,{lightparts} } } }
			
			for _,v2 in pairs(v:GetChildren()) do
				if v2:IsA("Light") then
					envLightOff(v2)
					table.insert(envLights,v2)
				elseif recognizeTextures then
					if v2:IsA("LayerCollector") then
						--recognize as a surface lighting method
						textureLightOff(v2)
						
						if config.brickLightColors[v2.Name] then
							--this lighto is defined specifically for a color
							if not textures["defined"][v2.Name] then --need to construct table
								textures["defined"][v2.Name] = {v2}
							else --table already exists, index this element to the table
								table.insert(textures["defined"][v2.Name],v2)
							end
						else
							--this lighto can be universally used
							
							local flashFXinstances = {}
							
							for _,v3 in pairs(v2:GetDescendants()) do --grab all flash FX
								if v3:IsA("ImageLabel") then
									table.insert(flashFXinstances,v3)
								end
							end
							
							table.insert(textures["universal"],{v2,flashFXinstances})
						end
					end
				end
			end
			
			allLightParts[v.Name] = {v,envLights,textures}
		end
	end
	
	--check for patterns and stages being used and index them to a table
	for _,patternData in pairs(patternsFolder:GetChildren()) do
		--every pattern
		local patternType,patternSteps,patternTempo,compiledPatternData = authenticatePattern.auth(car,patternData,lightsParent.Value,allLightParts)
		if patternType then
			if patternType[1] == "Stage" then
				allStageData[patternType[2]] = {patternSteps,60/patternTempo,compiledPatternData}
			elseif patternType[1] == "Dir" then
				allDirectorData[patternType[2]] = {patternSteps,60/patternTempo,compiledPatternData}
			end
		end
	end
	
	--compress tables to prevent empty stages
	do
		local newTable = {}
		for i=1,3 do
			if allStageData[i]~=nil then
				table.insert(newTable,allStageData[i])
			end
		end
		allStageData = newTable
	end
	do
		local newTable = {}
		for i=1,4 do
			if allDirectorData[i]~=nil then
				table.insert(newTable,allDirectorData[i])
			end
		end
		allDirectorData = newTable
	end
	
	--make a function for each stage
	for patternIndex,v in pairs(allStageData) do
		if allStageData[patternIndex][1] == 1 then
			--only 1 line, so lights never change.  (dont make a loop to change nothing)
			allStageData[patternIndex][4] = function()
				elsStep = 1
				for lightIndex,lightData in pairs(allStageData[patternIndex][3]) do --all lights
					if not table.find(lightsInvolvedInCurrentPattern["Director"],lightData[1][1]) then --make sure lights arent already running
						handleLightAction(lightData)
					end
				end
			end
		else
			--actually has multiple lines
			allStageData[patternIndex][4] = function()
				local function shouldBeRunning()
					return currentELSstage == patternIndex
				end

				while shouldBeRunning() do
					for frame = 1,allStageData[patternIndex][1] do
						elsStep = frame
						for lightIndex,lightData in pairs(allStageData[patternIndex][3]) do
							if not table.find(lightsInvolvedInCurrentPattern["Director"],lightData[1][1]) then
								handleLightAction(lightData,frame)
							end
						end
						task.wait(allStageData[patternIndex][2])
						if not shouldBeRunning() then
							break
						end
					end
				end
				
				elsStep = 0
			end
		end
	end
	
	--make a function for each director stage
	for patternIndex,v in pairs(allDirectorData) do
		if allDirectorData[patternIndex][1] == 1 then
			--only 1 line, so lights never change.  (dont make a loop to change nothing)
			allDirectorData[patternIndex][4] = function()
				directorStep = 1
				for lightIndex,lightData in pairs(allDirectorData[patternIndex][3]) do
					handleLightAction(lightData)
				end
			end
		else
			--actually has multiple lines
			allDirectorData[patternIndex][4] = function()
				local function shouldBeRunning()
					return currentDirectorStage == patternIndex
				end

				while shouldBeRunning() do
					for frame = 1,allDirectorData[patternIndex][1] do
						directorStep = frame
						for lightIndex,lightData in pairs(allDirectorData[patternIndex][3]) do
							handleLightAction(lightData,frame)
						end
						task.wait(allDirectorData[patternIndex][2])
						if not shouldBeRunning() then
							break
						end
					end
				end
				
				directorStep = 0
			end
		end
	end
	
	--//remove resources we dont need to prevent exploiters from grabbing light files
	script.Parent.Patterns:Destroy()
	script.Parent.LightsParent:Destroy()
	script:FindFirstChild("Rawcopy"):Destroy()
	script:FindFirstChild("AuthenticatePattern"):Destroy()
end

local function handleAddons()
	for _,addonModule in pairs(addons:GetChildren()) do
		if addonModule:IsA("ModuleScript") then
			--construct library
			local addonsLibrary = {}
			addonsLibrary.StageChanged = stageChangedSignal
			addonsLibrary.getCurrentStage = function() return currentELSstage,currentDirectorStage end
			addonsLibrary.keystroke = function(keycode)
				assert(keycode,".keystroke needs to be called with 1 KeyCode") --verify called with a keycode

				local keyCodeID = tostring(keycode) --define ID of keycode to group all callbacks associated with a key

				local __gcFunc = function(self) --called internally (through the signal object) when the signal needs to be GCd.  Self is the signal, which has no connections
					local ind = table.find(pluginKeyListeners[keyCodeID][2],self) --remove signal references to qualify for GC
					table.remove(pluginKeyListeners[keyCodeID][2],ind)
					if #pluginKeyListeners[keyCodeID][2] == 0 then
						if currentDriver then
							remote:InvokeClient(currentDriver,keycode,false) --tell client so send signals corresponding to this keycode
						end

						pluginKeyListeners[keyCodeID] = nil
					end
				end

				local keySignal = signalObject.new(__gcFunc) --make new signal object for this action

				if not pluginKeyListeners[keyCodeID] then
					pluginKeyListeners[keyCodeID] = {keycode,{}}
				end

				table.insert(pluginKeyListeners[keyCodeID][2], keySignal) --index signal object to table to be fired when signal is recieved from client
				
				if currentDriver then
					remote:InvokeClient(currentDriver,keycode,true) --tell client so send signals corresponding to this keycode
				end
				
				return keySignal
			end
			addonsLibrary.DriveSeat = driveSeat
			addonsLibrary.lightsParent = lightsParent.Value
			addonsLibrary.setLightEnabled = function(lightObject,state)
				assert(lightObject:IsDescendantOf(lightsParent.Value),"Light object must be a descendant of light parent")
				local ind = table.find(ignoreLights,lightObject)

				if state then
					if ind then
						table.remove(ignoreLights,ind)
						if lightObject:IsA("BasePart") then
							syncLight(lightObject)
						end
					end
				else
					if not ind then
						table.insert(ignoreLights,lightObject)
					end
				end
			end
			addonsLibrary.getLightEnabled = function(lightObject)
				assert(lightObject:IsDescendantOf(lightsParent.Value),"Light object must be a descendant of light parent")

				return (table.find(ignoreLights,lightObject)~=nil)
			end
			
			--run addon
			task.spawn(function()
				local s,e = pcall(function()
					require(addonModule)(addonsLibrary)
				end)

				if not s then
					warn(e)
				end
			end)
		end
	end
end

local function updateLightsInvolvedInPattern(switched)
	if switched == "MainELS" then
		lightsInvolvedInLastPattern["Stage"] = rawcopy(lightsInvolvedInCurrentPattern["Stage"])
		lightsInvolvedInCurrentPattern["Stage"] = {}
		
		if currentELSstage ~= 0 then
			for _,v in pairs(allStageData[currentELSstage][3]) do
				table.insert(lightsInvolvedInCurrentPattern["Stage"],v[1][1])
			end
		end
	elseif switched == "DirectorELS" then
		lightsInvolvedInLastPattern["Director"] = rawcopy(lightsInvolvedInCurrentPattern["Director"])
		lightsInvolvedInCurrentPattern["Director"] = {}
		
		if currentDirectorStage ~= 0 then
			for _,v in pairs(allDirectorData[currentDirectorStage][3]) do
				table.insert(lightsInvolvedInCurrentPattern["Director"],v[1][1])
			end
		end
	end
end

local function updateRunningPatterns(switched)
	updateLightsInvolvedInPattern(switched)	
	
	stageChangedSignal:Fire(currentELSstage,currentDirectorStage)
	
	if switched == "MainELS" then
		stageLightsOff()
		
		if currentELSstage ~= 0 then --run next stage
			allStageData[currentELSstage][4]()
		end
	elseif switched == "DirectorELS" then
		directorLightsOff()
		
		if currentDirectorStage ~=0 then
			allDirectorData[currentDirectorStage][4]()	
		end
	end
end

local function clientSignalRecieved(p,action,state)
	if action == "GetBinds" then --no need to secure a get function
		local listeners = {}
		for i,v in pairs(pluginKeyListeners) do
			table.insert(listeners,v[1])
		end
		return listeners
	end
	
	if currentDriver and p == currentDriver then
		if action == "MainELS" then --Cycle ELS
			if currentELSstage < #allStageData then --cycle stage
				currentELSstage+=1
			else
				currentELSstage=0
			end
			updateRunningPatterns(action) --play pattern for next stage
		elseif action == "DirectorELS" then
			if currentDirectorStage < #allDirectorData then --cycle stage
				currentDirectorStage+=1
			else
				currentDirectorStage=0
			end
			updateRunningPatterns(action) --play pattern for next stage
		else --must be a custom action
			warn(1)
			if pluginKeyListeners[action] then
				warn(2)
				for _,v in pairs(pluginKeyListeners[action][2]) do
					warn(3)
					v:Fire(state)
				end
			end
		end
	end
end

local function occupantChanged()
	local newOccupant = driveSeat.Occupant

	if newOccupant then
		local plr = players:GetPlayerFromCharacter(newOccupant.Parent)
		if plr then
			currentDriver = plr
		end
	else
		currentDriver = nil
	end
end

-----------
--//Core\\-
-----------

driveSeat:GetPropertyChangedSignal("Occupant"):Connect(occupantChanged)

initialize()
handleAddons()

remote.OnServerInvoke = clientSignalRecieved]]></ProtectedString>
