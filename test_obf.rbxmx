							<string name="ScriptGuid">{49D1406B-5A60-473E-8315-17CA352CB042}</string>
							<BinaryString name="AttributesSerialize"></BinaryString>
							<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
							<bool name="DefinesCapabilities">false</bool>
							<string name="Name">EasyLS_Server</string>
							<int64 name="SourceAssetId">-1</int64>
							<BinaryString name="Tags"></BinaryString>
						</Properties>
						<Item class="ModuleScript" referent="RBX38561D3E8E9945A399CDA0328AE21B69">
							<Properties>
								<Content name="LinkedSource"><null></null></Content>
								<ProtectedString name="Source"><![CDATA[local module = {}

local function errFile(mode,msg,trace)
	local traceStr = ""
	for i,v in pairs(trace) do
		traceStr = traceStr..">"..tostring(v)
	end
	mode("EasyLS light file failed to load: "..msg.."\n"..traceStr)
end

module.auth = function(car,patternFolder,lightsParent,allLightParts)
	--vars
	local validName = false
	local hasRequiredAmountofData = false
	local hasValidTempo = false
	local foundSteps = -1
	local foundTempo = -1
	
	local patternType = {"",0} --patternTypeStr,patternOrder
	local allModuleData = {}
	
	--eval folder name
	if string.sub(patternFolder.Name,1,5) == "Stage" then
		local stageNum = string.sub(patternFolder.Name,6,6)
		if stageNum and tonumber(stageNum) and tonumber(stageNum)>=1 and tonumber(stageNum)<=3 then
			patternType = {"Stage",tonumber(stageNum)}
			validName = true
		else
			errFile(warn,"Invalid pattern folder name",{car,patternFolder})
		end
	elseif string.sub(patternFolder.Name,1,8) == "Director" then
		local dirType = string.sub(patternFolder.Name,9,-1)
		local patternOrder = table.find({"Flash","Left","Right","Split"},dirType)
		if patternOrder then
			patternType = {"Dir",patternOrder}
			validName = true
		else
			errFile(warn,"Invalid pattern folder name",{car,patternFolder})
		end
	else
		errFile(warn,"Invalid pattern folder name",{car,patternFolder})
	end
	
	if not validName then return end
	
	--eval folder contents
	if #patternFolder:GetChildren()>0 then --bypass all of the errors for invalid pattern if the user doesnt want this to run anyways
		for _,v in pairs(patternFolder:GetChildren()) do --evaluate each light
			if v:IsA("ModuleScript") then --verify its actually a light file
				local modData = require(v) --grab light data from file
				if typeof(modData)=="table" then --verify file format
					if not modData["spacer"] then
						if modData["lightName"] and modData["lightName"] ~= "" then --verify file format
							local lightObj = allLightParts[modData["lightName"]] --verify light object exists
							if lightObj then
								local thisLightIsAlreadyScripted = false --make sure there arent dupped light files for one object
								for _,v2 in pairs(allModuleData) do
									if modData.lightName==v2.lightName then
										thisLightIsAlreadyScripted = true
										break
									end
								end
								if thisLightIsAlreadyScripted == false then
									if #modData.patternData>=1 then --make sure light file has a valid pattern
										if #modData.patternData == foundSteps or foundSteps == -1 then --make sure all light files have same amt of steps
											table.insert(allModuleData,{lightObj,modData.patternData})
											hasRequiredAmountofData = true
											foundSteps = #modData.patternData
										else
											errFile(warn,"Step amount inconsistency",{car,patternFolder,v})
										end
									end
								else
									errFile(warn,"Two light files found with same name",{car,patternFolder,v,"lightName"})
								end
							else
								errFile(warn,"Light name cant be found under light folder",{car,patternFolder,v,"lightName"})
							end
						else
							errFile(warn,"Invalid light name in file data",{car,patternFolder,v})
						end
					end
				else
					errFile(warn,"Invalid data format in file",{car,patternFolder,v})
				end
			elseif v:IsA("IntValue") then
				if v.Name == "Tempo" then
					if v.Value > 0 then
						hasValidTempo = true
						foundTempo = v.Value
					else
						errFile(warn,"Illegal pattern tempo",{car,patternFolder})
					end
				end
			end
		end
	else
		return
	end
	
	if not hasRequiredAmountofData then
		errFile(warn,"File has no light data",{car,patternFolder})
		return
	end
	if not hasValidTempo then
		errFile(warn,"Pattern has no tempo",{car,patternFolder})
		return
	end
	
	return patternType,foundSteps,foundTempo,allModuleData
end

return module]]></ProtectedString>
								<string name="ScriptGuid">{764F949D-2B93-4AC7-A907-EBB4EEC0B2AD}</string>
								<BinaryString name="AttributesSerialize"></BinaryString>
								<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
								<bool name="DefinesCapabilities">false</bool>
								<string name="Name">AuthenticatePattern</string>
								<int64 name="SourceAssetId">-1</int64>
								<BinaryString name="Tags"></BinaryString>
							</Properties>
						</Item>
						<Item class="ModuleScript" referent="RBXA0F8D18972A742ED80CBAFF745A83AA1">
							<Properties>
								<Content name="LinkedSource"><null></null></Content>
								<ProtectedString name="Source"><![CDATA[local f
f = function(orig)
	local orig_type = type(orig)
	local copy
	if orig_type == "table" then
		copy = {}
		for orig_key, orig_value in next, orig, nil do
			copy[f(orig_key)] = f(orig_value)
		end
		setmetatable(copy, f(getmetatable(orig)))
	else
		copy = orig
	end
	return copy
end

return f]]></ProtectedString>
								<string name="ScriptGuid">{C75AEB6D-C745-4ABE-9659-DE41BBC2DA71}</string>
								<BinaryString name="AttributesSerialize"></BinaryString>
								<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
								<bool name="DefinesCapabilities">false</bool>
								<string name="Name">Rawcopy</string>
								<int64 name="SourceAssetId">-1</int64>
								<BinaryString name="Tags"></BinaryString>
							</Properties>
						</Item>
						<Item class="ModuleScript" referent="RBX15478A05E9CD4219B95310976E9D62A2">
							<Properties>
								<Content name="LinkedSource"><null></null></Content>
								<ProtectedString name="Source"><![CDATA[local signal = {}

function signal.new(gcFunc)
	local self = setmetatable({},{__index=signal})
	
	self.__gcFunc = gcFunc or (function() end)
	self.connections = {}
	
	return self
end

function signal:Fire(...)
	for _,v in pairs(self.connections) do
		v.callback(...)
	end
end

function signal:Connect(f)
	local connection = require(script:WaitForChild("Connection")).new(self,f)
	table.insert(self.connections,connection)
	
	return connection
end

return signal]]></ProtectedString>
								<string name="ScriptGuid">{F8F21519-9371-4038-81C2-5EC9443F42EF}</string>
								<BinaryString name="AttributesSerialize"></BinaryString>
								<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
								<bool name="DefinesCapabilities">false</bool>
								<string name="Name">Signal</string>
								<int64 name="SourceAssetId">-1</int64>
								<BinaryString name="Tags"></BinaryString>
							</Properties>
							<Item class="ModuleScript" referent="RBXF34F1FE445834F11BE079E8E706CE486">
								<Properties>
									<Content name="LinkedSource"><null></null></Content>
									<ProtectedString name="Source"><![CDATA[local Connection = {}

function Connection.new(signal,callback)
	local self = setmetatable({},{__index=Connection})
	
	self.signal = signal
	self.callback = callback
	
	return self
end

function Connection:Disconnect()
	local ind = table.find(self.signal.connections,self)
	table.remove(self.signal.connections,ind)
	
	self.signal.__gcFunc(self.signal)
end

return Connection]]></ProtectedString>
									<string name="ScriptGuid">{E915A13C-E939-4D58-BB37-3A12CF5AF86E}</string>
									<BinaryString name="AttributesSerialize"></BinaryString>
